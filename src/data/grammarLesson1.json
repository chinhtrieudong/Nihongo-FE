{
    "lessonId": 1,
    "lessonTitle": "Bài 1: Xin chào",
    "sections": [
        {
            "id": "section1",
            "title": "Phần 1: Khẳng định và phủ định của danh từ",
            "structure": [
                "N は N です",
                "N は N じゃありません"
            ],
            "meaning": [
                "Khẳng định: là ~",
                "Phủ định: không phải ~"
            ],
            "examples": [
                "私は学生です。",
                "私は学生じゃありません。",
                "田中さんは先生です。",
                "田中さんは先生じゃありません。"
            ],
            "comparison": [
                "～です: Dùng trong văn nói, lịch sự",
                "～だ: Dùng trong văn viết, thân mật"
            ]
        },
        {
            "id": "section2",
            "title": "Phần 2: Trợ từ は",
            "structure": [
                "N は 〜"
            ],
            "meaning": [
                "Đánh dấu chủ ngữ trong câu",
                "Nhấn mạnh đối tượng đang nói đến"
            ],
            "examples": [
                "私はマイク・ミラーです。",
                "これは本です。",
                "田中さんは日本人です。"
            ]
        },
        {
            "id": "section3",
            "title": "Phần 3: Câu nghi vấn",
            "structure": [
                "N は N ですか",
                "N は N じゃありませんか"
            ],
            "meaning": [
                "Câu hỏi có/không",
                "か ở cuối câu biểu thị câu hỏi"
            ],
            "examples": [
                "あなたは学生ですか。",
                "田中さんは先生ですか。",
                "これは本ですか。"
            ]
        },
        {
            "id": "section4",
            "title": "Phần 4: Trợ từ も",
            "structure": [
                "N も 〜"
            ],
            "meaning": [
                "Cũng, cũng là",
                "Thay thế cho は khi muốn nói 'cũng'"
            ],
            "examples": [
                "私は学生です。田中さんも学生です。",
                "これは本です。それも本です。",
                "田中さんは日本人です。私も日本人です。"
            ],
            "comparison": [
                "は: Nhấn mạnh chủ ngữ",
                "も: Thêm vào ý nghĩa 'cũng'"
            ]
        },
        {
            "id": "section5",
            "title": "Phần 5: Trợ từ の",
            "structure": [
                "N1 の N2"
            ],
            "meaning": [
                "Của, thuộc về",
                "Nối hai danh từ, N1 sở hữu N2"
            ],
            "examples": [
                "私は学生です。",
                "これは私の本です。",
                "田中さんのかばんです。",
                "日本の車です。"
            ]
        },
        {
            "id": "section6",
            "title": "Phần 6: Đại từ chỉ định",
            "structure": [
                "これ/それ/あれ は N です",
                "この/その/あの N は 〜"
            ],
            "meaning": [
                "これ: Đây (gần người nói)",
                "それ: Đó (gần người nghe)",
                "あれ: Kia (xa cả hai)",
                "この/その/あの: đứng trước danh từ"
            ],
            "examples": [
                "これは本です。",
                "それはペンです。",
                "あれは何ですか。",
                "この本は私のです。",
                "その車は日本のです。",
                "あの建物は学校です。"
            ]
        },
        {
            "id": "section7",
            "title": "Phần 7: Câu hỏi với 何",
            "structure": [
                "これは何ですか",
                "N は何ですか"
            ],
            "meaning": [
                "何 (なん/なに): cái gì",
                "Hỏi về đối tượng không xác định"
            ],
            "examples": [
                "これは何ですか。",
                "それは何ですか。",
                "あなたのお名前は何ですか。",
                "これは何の本ですか。"
            ]
        },
        {
            "id": "section8",
            "title": "Phần 8: Đại từ nhân xưng",
            "structure": [
                "わたし/わたくし: tôi",
                "あなた: bạn",
                "あの方/あのかた: người kia (lịch sự)",
                "〜さん: ông/bà/cô/chú ~"
            ],
            "meaning": [
                "わたし: thông thường",
                "わたくし: trang trọng",
                "あなた: bạn (cần cẩn trọng khi dùng)",
                "あの方: lịch sự hơn あの人",
                "〜さん: hậu tố tôn trọng"
            ],
            "examples": [
                "わたしはマイク・ミラーです。",
                "あなたは学生ですか。",
                "あの方は田中さんです。",
                "田中さんは日本人です。"
            ]
        }
    ]
}