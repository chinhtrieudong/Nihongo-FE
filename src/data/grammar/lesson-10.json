          "vietnamese": "Trường có giáo viên."
        }
      ],
      "category": "existence_verbs"
    },
    {
      "id": "m10_03",
      "title": "上・下・中・前・後ろ・隣",
      "pattern": "〜の[Vị trí]に",
      "meaning": "trên/dưới/trong/trước/sau/cạnh",
      "explanation": "Kết hợp の + vị trí + に.",
      "structure": "**[Nơi]の[Vị trí]に[Đồ]があります**",
      "examples": [
        {
          "japanese": "机の上に本があります。",
          "vietnamese": "Trên bàn có sách."
        },
        {
          "japanese": "猫は椅子の下にいます。",
          "vietnamese": "Mèo ở dưới ghế."
        }
      ],
      "category": "location_words"
    },
    {
      "id": "m10_04",
      "title": "や (liệt kê)",
      "pattern": "〜や〜など",
      "meaning": "~, ~ v.v.",
      "explanation": "Liệt kê một phần, không đầy đủ.",
