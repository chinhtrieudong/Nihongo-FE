{
  "lessonNumber": 5,
  "level": "N5",
  "title": "Di chuyển & trợ từ",
  "title_jp": "移動動詞と助詞",
  "description": "行く・来る・帰る, へ, で, を, なんで",
  "grammars": [
    {
      "id": "m5_01",
      "title": "行きます・来ます・帰ります",
      "pattern": "行きます/来ます/帰ります",
      "meaning": "đi/đến/về",
      "explanation": "Ba động từ di chuyển cơ bản.",
      "structure": "**[Địa điểm]へ[Động từ]**",
      "examples": [
        {
          "japanese": "日{本|ほん}へ{行|い}きます。",
          "vietnamese": "Tôi đi Nhật."
        },
        {
          "japanese": "家へ{帰|かえ}ります。",
          "vietnamese": "Tôi về nhà."
        }
      ],
      "category": "direction_words"
    },
    {
      "id": "m5_02",
      "title": "へ (hướng)",
      "pattern": "〜へ行きます",
      "meaning": "đi về hướng ~",
      "explanation": "へ(đọc là \"e\") chỉ hướng di chuyển.",
      "structure": "**[Địa điểm]へ[Động từ di chuyển]**",
      "examples": [
        {
          "japanese": "{学校|がっこう}へ{行|い}きます。",
          "vietnamese": "Tôi đến trường."
        },
        {
          "japanese": "{駅|えき}へ{行|い}きます。",
          "vietnamese": "Tôi ra ga."
        }
      ],
      "category": "direction_words"
    },
    {
      "id": "m5_03",
      "title": "で (phương tiện)",
      "pattern": "〜で行きます",
      "meaning": "đi bằng ~",
      "explanation": "Chỉ phương tiện giao thông.",
      "structure": "**[PT]で[Động từ]**",
      "examples": [
        {
          "japanese": "バスで{学校|がっこう}へ{行|い}きます。",
          "vietnamese": "Đi học bằng bus."
        },
        {
          "japanese": "電{車|くるま}で{行|い}きます。",
          "vietnamese": "Đi bằng tàu điện."
        }
      ],
      "category": "basic_sentence_structure"
    },
    {
      "id": "m5_04",
      "title": "を (rời khỏi) & なんで",
      "pattern": "〜を出ます/なんで",
      "meaning": "rời ~ / bằng gì",
      "explanation": "を: rời khỏi nơi nào. なんで: phương tiện gì.",
      "structure": "**[Địa điểm]を出ます** / **なんで〜か**",
      "examples": [
        {
          "japanese": "8時に家を{出|で}ます。",
          "vietnamese": "8h rời nhà."
        },
        {
          "japanese": "なんで{行|い}きますか。",
          "vietnamese": "Đi bằng gì?"
        }
      ],
      "category": "basic_sentence_structure"
    }
  ]
}
