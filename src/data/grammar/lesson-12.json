  "title": "So sánh",
  "title_jp": "比較",
  "description": "Quá khứ tính từ, より, のほうが, いちばん",
  "grammars": [
    {
      "id": "m12_01",
      "title": "Quá khứ tính từ",
      "pattern": "〜かった/でした",
      "meaning": "đã ~",
      "explanation": "い: bỏい+かった. な: +でした.",
      "structure": "**[い]→かった / [な]+でした**",
      "examples": [
        {
          "japanese": "{昨日|きのう}は寒かったです。",
          "vietnamese": "Hôm qua lạnh."
        },
        {
          "japanese": "{{京都|きょうと}|きょうと}は{賑|にぎ}やかでした。",
          "vietnamese": "Kyoto nhộn nhịp."
        }
      ],
      "category": "adjectives"
    },
    {
      "id": "m12_02",
      "title": "〜より",
      "pattern": "〜より〜",
      "meaning": "hơn",
      "explanation": "AはBより = A hơn B.",
      "structure": "**[A]は[B]より[Tính từ]です**",
      "examples": [
        {
          "japanese": "{東京|とうきょう}は{大阪|おおさか}より{大|おお}きい。",
          "vietnamese": "Tokyo lớn hơn Osaka."
        },
        {
          "japanese": "日{本|ほん}語は{英語|えいご}より{難|むずか}しい。",
          "vietnamese": "Nhật khó hơn Anh."
        }
      ],
      "category": "comparison"
    },
    {
      "id": "m12_03",
      "title": "〜のほうが",
      "pattern": "〜のほうが〜",
      "meaning": "~ hơn",
      "explanation": "のほうが đánh dấu cái vượt trội.",
      "structure": "**[B]のほうが[A]より[Tính từ]です**",
      "examples": [
        {
          "japanese": "{大阪|おおさか}のほうが{安|やす}いです。",
          "vietnamese": "Osaka rẻ hơn."
        },
        {
          "japanese": "電{車|くるま}のほうが{速|はや}いです。",
          "vietnamese": "Tàu nhanh hơn."
        }
      ],
      "category": "comparison"
    },
    {
      "id": "m12_04",
      "title": "いちばん",
      "pattern": "〜でいちばん〜",
      "meaning": "nhất",
      "explanation": "いちばん = nhất. で = phạm vi.",
      "structure": "**[Phạm vi]でいちばん[Tính từ]です**",
      "examples": [
        {
          "japanese": "日{本|ほん}でいちばん{高|たか}い山は{富士山|ふじさん}。",
          "vietnamese": "Núi cao nhất NB là Phú Sĩ."
        }
      ],
      "category": "comparison"
    }
  ]
}
