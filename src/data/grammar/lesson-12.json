          "japanese": "電車のほうが速いです。",
          "vietnamese": "Tàu nhanh hơn."
        }
      ],
      "category": "comparison"
    },
    {
      "id": "m12_04",
      "title": "いちばん",
      "pattern": "〜でいちばん〜",
      "meaning": "nhất",
      "explanation": "いちばん = nhất. で = phạm vi.",
      "structure": "**[Phạm vi]でいちばん[Tính từ]です**",
